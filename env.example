# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-haiku-4-5

# App
ENVIRONMENT=development
LOG_LEVEL=info

# Optional: platform publishing (day 9+)
# INSTAGRAM_ACCESS_TOKEN=
LINKEDIN_ACCESS_TOKEN=your_linkedin_personal_access_token
LINKEDIN_PERSON_URN=urn:li:person:your_person_id

# Gmail idea scanner
# 1. Create a project at console.cloud.google.com
# 2. Enable the Gmail API
# 3. Create OAuth credentials (Desktop app) and download as credentials.json
# 4. Run: python orchestra/examples/gmail_auth.py
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=token.json
